---
import { siteContent } from '../../data/content';

const { hero } = siteContent;
---

<section class="mx-auto max-w-content px-6 md:px-10">
  <div
    class="grid min-h-[70vh] items-center gap-12 py-16 md:grid-cols-2 md:gap-16 md:py-24"
  >
    <!-- Columna de texto -->
    <div class="max-w-xl">
      <p
        class="text-xs font-medium uppercase tracking-wideish text-ink-muted"
        data-reveal
      >
        {hero.eyebrow}
      </p>
      <h1
        class="mt-6 font-display text-4xl font-medium leading-[1.08] tracking-tight sm:text-5xl lg:text-6xl"
        data-reveal
        style="--reveal-delay: 90ms"
      >
        {hero.title}
      </h1>
      <p
        class="mt-6 text-base leading-relaxed text-ink-muted md:text-lg"
        data-reveal
        style="--reveal-delay: 180ms"
      >
        {hero.subtitle}
      </p>

      <div
        class="mt-10 flex flex-wrap items-center gap-4"
        data-reveal
        style="--reveal-delay: 270ms"
      >
        <a
          href={hero.ctaPrimary.href}
          class="inline-block bg-ink px-7 py-3.5 text-sm font-medium text-cream transition-colors hover:bg-ink-muted"
        >
          {hero.ctaPrimary.label}
        </a>
        <a
          href={hero.ctaSecondary.href}
          class="inline-block px-2 py-3.5 text-sm font-medium text-ink underline decoration-sage decoration-2 underline-offset-8 transition-colors hover:decoration-sage-deep"
        >
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>

    <!-- Columna visual: placeholder hasta subir la foto del Drive -->
    <div class="relative" data-reveal style="--reveal-delay: 150ms">
      {
        hero.imageSrc ? (
          <img
            src={hero.imageSrc}
            alt={hero.imageAlt}
            class="aspect-[4/5] w-full object-cover"
            loading="eager"
          />
        ) : (
          <div
            class="relative flex aspect-[4/5] w-full items-end bg-sage p-8"
            role="img"
            aria-label={hero.imageAlt}
          >
            <div class="absolute inset-6 border border-cream/50" aria-hidden="true" />
            <p class="relative font-display text-sm italic text-ink/70">
              {hero.imageAlt}
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>
