---
import { siteContent } from '../../data/content';
import ServiceCard from '../ui/ServiceCard';

const { services } = siteContent;
---

<section id="servicios" class="border-t border-line">
  <div class="mx-auto max-w-content px-6 py-24 md:px-10 md:py-32">
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-wideish text-ink-muted">
        {services.eyebrow}
      </p>
      <h2
        class="mt-5 font-display text-3xl font-medium leading-snug tracking-tight md:text-4xl"
      >
        {services.title}
      </h2>
      <p class="mt-5 text-base leading-relaxed text-ink-muted md:text-lg">
        {services.intro}
      </p>
    </div>

    <div class="mt-16 grid gap-px border border-line bg-line sm:grid-cols-2">
      {services.items.map((service) => <ServiceCard service={service} />)}
    </div>
  </div>
</section>
