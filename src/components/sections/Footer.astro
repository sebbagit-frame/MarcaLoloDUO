---
import { siteContent } from '../../data/content';

const { brand, footer } = siteContent;
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div
    class="mx-auto flex max-w-content flex-col gap-2 px-6 py-10 text-sm text-ink-muted sm:flex-row sm:items-center sm:justify-between md:px-10"
  >
    <p>© {year} {brand.name}</p>
    <p class="font-display italic">{footer.note}</p>
  </div>
</footer>
