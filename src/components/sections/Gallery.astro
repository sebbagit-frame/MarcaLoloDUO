---
import { siteContent } from '../../data/content';
import type { GalleryItem } from '../../domain/types';

const { gallery } = siteContent;

const aspectClass: Record<GalleryItem['aspect'], string> = {
  portrait: 'aspect-[3/4]',
  landscape: 'aspect-[4/3]',
  square: 'aspect-square',
};

// Tonos alternados para que los placeholders respiren como una retícula editorial.
const placeholderTones = ['bg-sage', 'bg-sage-soft', 'bg-line'] as const;
---

<section id="galeria" class="border-t border-line">
  <div class="mx-auto max-w-content px-6 py-24 md:px-10 md:py-32">
    <div class="max-w-2xl" data-reveal>
      <p class="text-xs font-medium uppercase tracking-wideish text-ink-muted">
        {gallery.eyebrow}
      </p>
      <h2
        class="mt-5 font-display text-3xl font-medium leading-snug tracking-tight md:text-4xl"
      >
        {gallery.title}
      </h2>
    </div>

    <div class="mt-16 columns-1 gap-6 sm:columns-2 lg:columns-3 [&>figure]:mb-6">
      {
        gallery.items.map((item, i) => (
          <figure
            class="break-inside-avoid"
            data-reveal
            style={`--reveal-delay: ${Math.min(i * 80, 400)}ms`}
          >
            {item.src ? (
              <img
                src={item.src}
                alt={item.alt}
                class={`w-full object-cover ${aspectClass[item.aspect]}`}
                loading="lazy"
              />
            ) : (
              <div
                class={`flex w-full items-end p-6 ${aspectClass[item.aspect]} ${placeholderTones[i % placeholderTones.length]}`}
                role="img"
                aria-label={item.alt}
              >
                <span
                  class="font-display text-xs italic text-ink/50"
                  aria-hidden="true"
                >
                  {item.caption}
                </span>
              </div>
            )}
            <figcaption class="mt-3 text-xs uppercase tracking-wideish text-ink-muted">
              {item.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
