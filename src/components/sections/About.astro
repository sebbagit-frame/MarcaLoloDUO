---
import { siteContent } from '../../data/content';

const { about } = siteContent;
---

<section id="sobre" class="border-t border-line">
  <div class="mx-auto max-w-content px-6 py-24 md:px-10 md:py-32">
    <div class="grid gap-12 md:grid-cols-12 md:gap-8">
      <!-- Encabezado de sección -->
      <div class="md:col-span-4">
        <p
          class="text-xs font-medium uppercase tracking-wideish text-ink-muted"
        >
          {about.eyebrow}
        </p>
        <h2
          class="mt-5 font-display text-3xl font-medium leading-snug tracking-tight md:text-4xl"
        >
          {about.title}
        </h2>
      </div>

      <!-- Cuerpo -->
      <div class="md:col-span-7 md:col-start-6">
        <div class="space-y-6">
          {
            about.paragraphs.map((paragraph) => (
              <p class="text-base leading-relaxed text-ink-muted md:text-lg">
                {paragraph}
              </p>
            ))
          }
        </div>

        <dl class="mt-14 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-4">
          {
            about.highlights.map((highlight) => (
              <div class="border-t border-sage pt-4">
                <dd class="font-display text-3xl font-medium text-ink">
                  {highlight.value}
                </dd>
                <dt class="mt-1 text-xs uppercase tracking-wideish text-ink-muted">
                  {highlight.label}
                </dt>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>
